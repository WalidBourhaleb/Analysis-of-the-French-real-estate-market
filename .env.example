# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL Connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=immobilier_db
DB_USER=immo_user
DB_PASSWORD=your_secure_password_here

# Database URL (generated from above, no need to change)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}


# =============================================================================
# API KEYS (Optional - Most APIs are public/free)
# =============================================================================

# DVF API (Data.gouv.fr - Usually no key needed, API is public)
DVF_API_KEY=

# INSEE API (Free after registration at https://api.insee.fr)
# Register here: https://api.insee.fr/catalogue/
INSEE_API_KEY=

# Google Maps API (Optional - For advanced geocoding)
# Get key at: https://console.cloud.google.com/apis/credentials
# Free tier: 200$/month (28,000 requests)
GOOGLE_MAPS_API_KEY=

# OpenWeatherMap API (Optional - For weather data enrichment)
OPENWEATHER_API_KEY=


# =============================================================================
# SCRAPING CONFIGURATION
# =============================================================================

# Delays between requests (in seconds) - Respect websites
SCRAPING_DELAY_MIN=3
SCRAPING_DELAY_MAX=7

# Maximum pages to scrape per search
MAX_PAGES_PER_SEARCH=5

# Maximum listings per day (to stay respectful)
MAX_LISTINGS_PER_DAY=30

# User Agent (simulate real browser)
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# Proxy settings (leave empty if not using proxies)
PROXY_URL=
PROXY_USERNAME=
PROXY_PASSWORD=


# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Environment (development, staging, production)
ENVIRONMENT=development

# Debug mode (True for development, False for production)
DEBUG=True

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path
LOG_FILE=logs/app.log


# =============================================================================
# MACHINE LEARNING CONFIGURATION
# =============================================================================

# Model version
MODEL_VERSION=v1.0

# Random seed for reproducibility
RANDOM_SEED=42

# Train/test split ratio
TEST_SIZE=0.2

# Model parameters
ML_N_ESTIMATORS=200
ML_MAX_DEPTH=15
ML_LEARNING_RATE=0.05


# =============================================================================
# STREAMLIT DASHBOARD (For deployment)
# =============================================================================

# Server settings
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost
STREAMLIT_SERVER_HEADLESS=true

# Theme
STREAMLIT_THEME_BASE=light
STREAMLIT_THEME_PRIMARY_COLOR=#FF4B4B

# Cache settings (in seconds)
CACHE_TTL=3600


# =============================================================================
# GEOCODING SERVICE
# =============================================================================

# Choose: 'nominatim' (free, no key needed) or 'google' (needs API key)
GEOCODING_SERVICE=nominatim

# Nominatim settings (OpenStreetMap - Free)
NOMINATIM_URL=https://nominatim.openstreetmap.org/search
NOMINATIM_USER_AGENT=immobilier-analysis-app


# =============================================================================
# DATA QUALITY THRESHOLDS
# =============================================================================

# Minimum and maximum acceptable values for data cleaning
MIN_PRICE=10000
MAX_PRICE=10000000
MIN_SURFACE=9
MAX_SURFACE=1000
MIN_PRICE_M2=500
MAX_PRICE_M2=20000


# =============================================================================
# SCHEDULER SETTINGS (For automated scraping)
# =============================================================================

# Run scraper daily at specific time (24h format)
SCRAPER_SCHEDULE_TIME=02:00

# Enable/disable automated scraping
AUTO_SCRAPING_ENABLED=false


# =============================================================================
# EMAIL NOTIFICATIONS (Optional - For alerts)
# =============================================================================

# SMTP settings for sending email alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_EMAIL_TO=your-email@gmail.com


# =============================================================================
# CLOUD STORAGE (Optional - For backup)
# =============================================================================

# AWS S3 (if backing up data to cloud)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
AWS_REGION=eu-west-3


# =============================================================================
# NOTES
# =============================================================================

# After copying this file:
# 1. Copy to .env:    cp .env.example .env
# 2. Edit .env with your real values
# 3. NEVER commit .env to Git (it's in .gitignore)
# 4. Keep .env.example updated when adding new variables